# Dockerfile.dev
# Imagem para desenvolvimento local com hot-reload.
# Usada pelo docker-compose.yml.
# NÃO usar em produção — use o Dockerfile principal.

FROM node:20-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Instalar dependências (serão sobrescritas pelo volume mount)
COPY package.json package-lock.json* ./
RUN npm ci

# Gerar Prisma client dentro da imagem
COPY prisma ./prisma
RUN npx prisma generate

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# O código real é montado via volume no docker-compose.yml
# O comando de start é definido no docker-compose.yml
CMD ["npm", "run", "dev"]
