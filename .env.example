# .env.example — copie para .env.local (dev) ou configure como secrets no Swarm

# ── Banco de dados ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://pacoticket:senha@localhost:5432/pacoticket_site"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-segredo-aqui"
NEXTAUTH_URL="http://localhost:3000"   # em produção: https://pacoticket.com.br

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@pacoticket.com.br"
ADMIN_PASSWORD="troque-isso-agora"

# ── Postgres (usado no docker-stack.yml) ───────────────────────────────────────
POSTGRES_PASSWORD="senha-postgres"

# ── Cloudflare R2 (upload de imagens) — opcional ───────────────────────────────
# Crie um bucket no Cloudflare R2 e gere credenciais API em:
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# URL pública do bucket (ex: https://pub-xxx.r2.dev ou domínio customizado)
R2_PUBLIC_URL=""
